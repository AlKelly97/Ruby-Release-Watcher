<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Release Watcher</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 2rem; }
      table { border-collapse: collapse; width: 100%; max-width: 800px; }
      th, td { border: 1px solid #ccc; padding: 0.5rem; text-align: left; }
      th { background: #f5f5f5; }
    </style>
  </head>
  <body>
    <h1>Release Watcher</h1>

    <!-- Flash Message Area -->
    <% if flash[:success] %>
      <div style="background: #d4edda; color: #155724; padding: 1rem; margin-bottom: 1rem; border-radius: 4px;">
        <%= flash[:success] %>
      </div>
    <% end %>

    <% if flash[:error] %>
  <div style="background: #f8d7da; color: #721c24; padding: 1rem; margin-bottom: 1rem; border-radius: 4px;">
    <%= flash[:error] %>
  </div>
<% end %>

    <!-- Add Project form -->
    <form action="/projects" method="post" style="margin-bottom: 2rem;">
      <input type="text" name="name" placeholder="Project Name" required style="padding: 0.5rem; margin-right: 0.5rem;">
      <select name="source" placeholder="Source (e.g., github)" required style="padding: 0.5rem; margin-right: 0.5rem;">
        <option value="github">github</option>
        <option value="steam">steam</option>
        <option value="website">website</option>
      </select>
      <input type="url" name="url" placeholder="Project URL" required style="padding: 0.5rem; margin-right: 0.5rem;">
      <button type="submit">Add Project</button>
    </form>

    <form action="/refresh_all" method="post" style="margin-bottom: 1rem;">
      <button type="submit">Refresh All Github</button>
    </form>

    <p>Current video games and romhacks being watched (static for now)</p>

    <table>
      <thead>
        <tr>
          <th>Project</th>
          <th>Source</th>
          <th>URL</th>
          <th>Latest Release</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td><%= project[:name] %></td>
            <td><%= project[:source] %></td>
            <td><a href="<%= project[:url] %>" target="_blank"><%= project[:url] %></a></td>
            <td>
              <% if project[:latest_release_tag] %>
                <a href="<%= project[:latest_release_url] %>" target="_blank"><%= project[:latest_release_tag] %></a>
                <div style="font-size: 0.85em; color: #666;"><%= project[:latest_release_published_at]%> <br> <b>Last checked:</b> <%= project[:last_checked_at] || "Never" %>
                </div>
              <% else %>
              <em>Not fetched</em>
              <% end %>
            </td>

            <td>
              <% if project[:source_key] == "github" %>
                <form action="/projects/<%= project[:id] %>/refresh" method="post" style="display:inline;">
                  <button type="submit">Refresh</button>
                </form>
              <% end %>

              <form action="/projects/<%= project[:id] %>" method="post" style="display: inline;">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" onclick="return confirm('Delete?')">Delete</button>
              </form>
          </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </body>
</html>